generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                   String                @id @default(uuid())
  email                String                @unique
  phone                String?
  fullName             String
  avatarUrl            String?
  role                 UserRole              @default(BUYER)
  kycStatus            KycStatus             @default(PENDING)
  passwordHash         String?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  savedProperties      SavedProperty[]
  showings             Showing[]
  offers               Offer[]
  notifications        Notification[]
  identityVerification IdentityVerification?
  sessions             Session[]

  @@map("users")
}

enum UserRole {
  BUYER
  ADMIN
  AGENT
}

enum KycStatus {
  PENDING
  SUBMITTED
  VERIFIED
  FAILED
}

model Session {
  id        String   @id @default(uuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model IdentityVerification {
  id         String             @id @default(uuid())
  userId     String             @unique
  provider   String
  externalId String?
  status     VerificationStatus @default(PENDING)
  verifiedAt DateTime?
  createdAt  DateTime           @default(now())
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("identity_verifications")
}

enum VerificationStatus {
  PENDING
  PROCESSING
  VERIFIED
  FAILED
}

model Property {
  id           String         @id @default(uuid())
  externalId   String?
  source       String         @default("internal")
  address      String
  city         String
  state        String
  zipCode      String
  price        Decimal        @db.Decimal(12, 2)
  bedrooms     Int?
  bathrooms    Decimal?       @db.Decimal(4, 1)
  sqft         Int?
  lotSize      Decimal?
  yearBuilt    Int?
  propertyType PropertyType   @default(SINGLE_FAMILY)
  status       PropertyStatus @default(ACTIVE)
  description  String?
  images       Json           @default("[]")
  features     Json           @default("{}")
  rawData      Json?
  listedAt     DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  savedBy      SavedProperty[]
  showings     Showing[]
  offers       Offer[]

  @@index([city, state])
  @@index([status])
  @@index([price])
  @@map("properties")
}

enum PropertyType {
  SINGLE_FAMILY
  CONDO
  TOWNHOUSE
  MULTI_FAMILY
  LAND
  OTHER
}

enum PropertyStatus {
  ACTIVE
  PENDING
  SOLD
  OFF_MARKET
}

model SavedProperty {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  notes      String?
  savedAt    DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@unique([userId, propertyId])
  @@map("saved_properties")
}

model Showing {
  id          String        @id @default(uuid())
  userId      String
  propertyId  String
  requestedAt DateTime
  confirmedAt DateTime?
  status      ShowingStatus @default(REQUESTED)
  notes       String?
  contactInfo Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  property    Property      @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("showings")
}

enum ShowingStatus {
  REQUESTED
  CONFIRMED
  COMPLETED
  CANCELLED
}

model Offer {
  id             String          @id @default(uuid())
  userId         String
  propertyId     String
  offerPrice     Decimal         @db.Decimal(12, 2)
  earnestMoney   Decimal?        @db.Decimal(12, 2)
  downPayment    Decimal?        @db.Decimal(12, 2)
  financingType  FinancingType   @default(CONVENTIONAL)
  contingencies  Json            @default("{}")
  expirationDate DateTime?
  status         OfferStatus     @default(DRAFT)
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  user           User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  property       Property        @relation(fields: [propertyId], references: [id], onDelete: Cascade)
  documents      OfferDocument[]
  timeline       TransactionEvent[]

  @@map("offers")
}

enum FinancingType {
  CONVENTIONAL
  FHA
  VA
  CASH
  OTHER
}

enum OfferStatus {
  DRAFT
  SUBMITTED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  COUNTERED
  WITHDRAWN
}

model OfferDocument {
  id           String    @id @default(uuid())
  offerId      String
  documentType String
  fileUrl      String
  signed       Boolean   @default(false)
  signedAt     DateTime?
  createdAt    DateTime  @default(now())
  offer        Offer     @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@map("offer_documents")
}

model TransactionEvent {
  id          String      @id @default(uuid())
  offerId     String
  eventType   String
  title       String
  description String?
  status      EventStatus @default(PENDING)
  dueDate     DateTime?
  completedAt DateTime?
  createdAt   DateTime    @default(now())
  offer       Offer       @relation(fields: [offerId], references: [id], onDelete: Cascade)

  @@map("transaction_events")
}

enum EventStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  read      Boolean  @default(false)
  metadata  Json     @default("{}")
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@map("notifications")
}
